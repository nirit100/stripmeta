---
---

<details id="settings-details" class="w-full group border border-base-300 rounded-xl overflow-hidden">
  <summary class="list-none flex items-center gap-2 px-4 py-3 cursor-pointer select-none hover:bg-base-200/60 transition-colors">
    <svg class="w-3 h-3 text-base-content/40 transition-transform group-open:rotate-90 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-xs font-medium uppercase tracking-widest text-base-content/70">Settings</span>
  </summary>
  <div class="settings-body border-t border-base-300 divide-y divide-base-300">
    <p class="px-4 pt-3 pb-1 text-[0.65rem] font-semibold uppercase tracking-widest text-base-content/40">Processing</p>
    <label class="flex items-center justify-between gap-4 px-4 py-3 cursor-pointer select-none hover:bg-base-200/40 transition-colors">
      <div>
        <p class="text-sm font-medium">Paranoid mode</p>
        <p class="text-xs text-base-content/50">Always re-encode via canvas — strips everything, but output is <b>always JPEG</b>. Small quality loss.</p>
        <p class="text-xs text-base-content/50">Only use when you're really paranoid.</p>
      </div>
      <input type="checkbox" id="toggle-paranoid" class="toggle toggle-sm toggle-warning shrink-0" />
    </label>
    <label class="flex items-center justify-between gap-4 px-4 py-3 cursor-pointer select-none hover:bg-base-200/40 transition-colors">
      <div>
        <p class="text-sm font-medium">Skip files with no found metadata</p>
        <p class="text-xs text-base-content/50">If disabled they will be processed anyways.</p>
      </div>
      <input type="checkbox" id="toggle-skip-clean" class="toggle toggle-sm shrink-0" checked />
    </label>
    <label class="flex items-center justify-between gap-4 px-4 py-3 cursor-pointer select-none hover:bg-base-200/40 transition-colors">
      <div>
        <p class="text-sm font-medium">Skip unsupported files</p>
        <p class="text-xs text-base-content/50">This tool really supports the most common image formats (e.g. JPEG, PNG, WEBP). If disabled, images in other formats are re-encoded to JPEG via the canvas method.</p>
      </div>
      <input type="checkbox" id="toggle-skip-unsupported" class="toggle toggle-sm shrink-0" checked />
    </label>
    <label class="flex items-center justify-between gap-4 px-4 py-3 cursor-pointer select-none hover:bg-base-200/40 transition-colors">
      <div>
        <p class="text-sm font-medium">Copy skipped files to output</p>
        <p class="text-xs text-base-content/50">Include skipped files unchanged in the download, so the output is always complete.</p>
      </div>
      <input type="checkbox" id="toggle-include-skipped" class="toggle toggle-sm shrink-0" />
    </label>
    <p class="px-4 pt-3 pb-1 text-[0.65rem] font-semibold uppercase tracking-widest text-base-content/40">Appearance & Usability</p>
    <label class="flex items-center justify-between gap-4 px-4 py-3 cursor-pointer select-none hover:bg-base-200/40 transition-colors">
      <div>
        <p class="text-sm font-medium">Warn before leaving with files loaded</p>
        <p class="text-xs text-base-content/50">Shows a browser confirmation if you try to close or reload the tab while images are loaded.</p>
      </div>
      <input type="checkbox" id="toggle-warn-unload" class="toggle toggle-sm shrink-0" checked />
    </label>
    <label class="flex items-center justify-between gap-4 px-4 py-3 cursor-pointer select-none hover:bg-base-200/40 transition-colors">
      <div>
        <p class="text-sm font-medium">Disable frosted glass</p>
        <p class="text-xs text-base-content/50">Remove blur effects from floating elements.</p>
      </div>
      <input type="checkbox" id="toggle-no-glass" class="toggle toggle-sm shrink-0" />
    </label>
    <p class="px-4 pt-3 pb-1 text-[0.65rem] font-semibold uppercase tracking-widest text-base-content/40">Technical stuff</p>
    <div>
      <label class="flex items-center justify-between gap-4 px-4 py-3 cursor-pointer select-none hover:bg-base-200/40 transition-colors">
        <div>
          <p class="text-sm font-medium">Remember settings</p>
          <p class="text-xs text-base-content/50">
            Settings are saved in your browser's local storage and restored on your next visit if enabled.<br />
            Don't worry, the server never sees them.
          </p>
        </div>
        <input type="checkbox" id="toggle-persist" class="toggle toggle-sm shrink-0" checked />
      </label>
      <div id="clear-storage-hint" class="items-center justify-between gap-2 px-4 text-xs text-base-content/70">
        <span>⚠️ <b>Previously saved settings still exist in local storage!</b></span>
        <button id="btn-clear-storage" type="button" class="btn btn-xs btn-ghost text-error/70 hover:text-error shrink-0">Clear local storage now</button>
      </div>
    </div>
  </div>
</details>
