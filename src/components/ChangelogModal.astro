---
// "What's new" dialog. Body is filled at runtime by src/scripts/changelog.ts
// from the entries newer than the user's last acknowledged version.
import Icon from './Icon.astro';
---

<dialog id="changelog-modal" class="modal">
  <div class="modal-box max-w-md p-0 overflow-hidden bg-transparent flex flex-col max-h-[85vh]">

    <div class="flex items-center gap-3 px-5 py-4 border-b border-base-300/60 shrink-0 bg-base-100/75 backdrop-blur-xl backdrop-brightness-125 glass-elem">
      <h3 class="font-bold text-lg flex-1 min-w-0 flex items-center gap-2"><Icon name="sparkles" class="w-5 h-5 text-base-content/60" />What's new</h3>
      <form method="dialog">
        <button class="btn btn-ghost btn-sm btn-circle text-base-content/50">✕</button>
      </form>
    </div>

    <div id="changelog-modal-body" class="overflow-y-auto flex-1 space-y-6 px-5 py-5 bg-base-100"></div>

    <div class="flex justify-end px-5 py-3 border-t border-base-300/60 shrink-0 bg-base-100">
      <a href="/changelog" class="text-xs text-base-content/50 hover:text-base-content/80 transition-colors">
        Full changelog &rarr;
      </a>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
