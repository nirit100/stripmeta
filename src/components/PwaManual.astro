---
---

<!-- Safari iOS / iPadOS — all browsers, share sheet flow -->
<div data-platform="safari-ios" class="hidden flex flex-col gap-5 px-5 py-5 text-sm bg-base-100">
  <div class="flex gap-3.5">
    <div class="shrink-0 w-6 h-6 rounded-full bg-primary/15 text-primary text-xs font-bold flex items-center justify-center mt-0.5">1</div>
    <div class="flex flex-col gap-2 min-w-0">
      <p class="text-base-content">Tap the <strong>Share</strong> button in your browser's toolbar</p>
      <div class="inline-flex items-center px-3 py-2 rounded-lg bg-base-200 border border-base-300/70 text-base-content/65 text-xs w-fit shadow-sm">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-label="Share"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
      </div>
      <p class="text-xs text-base-content/45">Looks like a box with an arrow pointing up</p>
    </div>
  </div>
  <div class="flex gap-3.5">
    <div class="shrink-0 w-6 h-6 rounded-full bg-primary/15 text-primary text-xs font-bold flex items-center justify-center mt-0.5">2</div>
    <div class="flex flex-col gap-2 min-w-0">
      <p class="text-base-content">Tap <strong>Add to Home Screen</strong></p>
      <div class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-base-200 border border-base-300/70 text-base-content/65 text-xs w-fit shadow-sm font-medium">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M12 8v8M8 12h8"/></svg>
        Add to Home Screen
      </div>
      <p class="text-xs text-base-content/45">Scroll down in the share sheet if you don't see it</p>
    </div>
  </div>
  <div class="flex gap-3.5">
    <div class="shrink-0 w-6 h-6 rounded-full bg-primary/15 text-primary text-xs font-bold flex items-center justify-center mt-0.5">3</div>
    <div class="flex flex-col gap-1.5 min-w-0">
      <p class="text-base-content">Tap <strong>Add</strong> to confirm</p>
      <p class="text-xs text-base-content/45">StripMeta will appear on your Home Screen like any other app</p>
    </div>
  </div>
</div>

<!-- Firefox Android -->
<div data-platform="firefox-android" class="hidden flex flex-col gap-5 px-5 py-5 text-sm bg-base-100">
  <div class="flex gap-3.5">
    <div class="shrink-0 w-6 h-6 rounded-full bg-primary/15 text-primary text-xs font-bold flex items-center justify-center mt-0.5">1</div>
    <div class="flex flex-col gap-2 min-w-0">
      <p class="text-base-content">Tap the <strong>menu button</strong> in the browser toolbar</p>
      <div class="inline-flex items-center px-3 py-2 rounded-lg bg-base-200 border border-base-300/70 text-base-content/65 text-xs w-fit shadow-sm">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-label="Menu"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>
      </div>
    </div>
  </div>
  <div class="flex gap-3.5">
    <div class="shrink-0 w-6 h-6 rounded-full bg-primary/15 text-primary text-xs font-bold flex items-center justify-center mt-0.5">2</div>
    <div class="flex flex-col gap-2 min-w-0">
      <p class="text-base-content">Tap <strong>Add app to Home Screen</strong></p>
      <div class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-base-200 border border-base-300/70 text-base-content/65 text-xs w-fit shadow-sm font-medium">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12M8.5 11.5l3.5 3.5 3.5-3.5"/><path d="M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/></svg>
        Add app to Home Screen
      </div>
    </div>
  </div>
</div>

<!-- Safari macOS (Sonoma+) -->
<div data-platform="safari-macos" class="hidden flex flex-col gap-5 px-5 py-5 text-sm bg-base-100">
  <div class="flex gap-3.5">
    <div class="shrink-0 w-6 h-6 rounded-full bg-primary/15 text-primary text-xs font-bold flex items-center justify-center mt-0.5">1</div>
    <div class="flex flex-col gap-2 min-w-0">
      <p class="text-base-content">In the menu bar at the top of your screen, click <strong>File</strong></p>
      <div class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-base-200 border border-base-300/70 text-base-content/65 text-xs w-fit shadow-sm font-medium">
        File
      </div>
    </div>
  </div>
  <div class="flex gap-3.5">
    <div class="shrink-0 w-6 h-6 rounded-full bg-primary/15 text-primary text-xs font-bold flex items-center justify-center mt-0.5">2</div>
    <div class="flex flex-col gap-2 min-w-0">
      <p class="text-base-content">Click <strong>Add to Dock…</strong></p>
      <div class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-base-200 border border-base-300/70 text-base-content/65 text-xs w-fit shadow-sm font-medium">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 8v8M8 12h8"/></svg>
        Add to Dock…
      </div>
      <p class="text-xs text-base-content/45">Requires macOS Sonoma or later and Safari 17+</p>
    </div>
  </div>
</div>
