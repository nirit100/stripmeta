---
import Brand from './Brand.astro';

const kofiId          = import.meta.env.PUBLIC_KOFI_ID          as string;
const paypalDonateUrl = import.meta.env.PUBLIC_PAYPAL_DONATE_URL as string;
const githubUrl       = import.meta.env.PUBLIC_GITHUB_URL        as string;
---

<dialog id="about-modal" class="modal">
  <div class="modal-box max-w-xlg p-0 overflow-hidden bg-transparent">
    <div class="flex items-center gap-3 px-5 py-4 border-b border-base-300/60 bg-base-100/75 backdrop-blur-xl backdrop-brightness-125 glass-elem">
      <div class="flex-1 min-w-0">
        <h3 class="font-bold text-lg">About <Brand /></h3>
      </div>
      <form method="dialog">
        <button class="btn btn-ghost btn-sm btn-circle text-base-content/50">✕</button>
      </form>
    </div>

    <div id="about-stats" class="hidden border-b border-base-300/60 bg-base-100 px-5 pt-5 pb-4">
      <div class="flex items-center justify-between mb-4">
        <p class="text-[0.65rem] font-semibold uppercase tracking-widest text-base-content/35">Cleaned this session</p>
        <p id="stats-date" class="text-[0.65rem] text-base-content/30 italic"></p>
      </div>
      <div class="flex flex-wrap justify-around gap-x-4 gap-y-3 text-center">
        <div class="flex flex-col items-center gap-0.5 min-w-[4rem]">
          <span class="text-3xl font-bold brand-name tabular-nums" id="stat-files">0</span>
          <span class="text-xs text-base-content/45 mt-1">🖼️ files cleaned</span>
        </div>
        <div id="stat-gps-wrap" class="flex flex-col items-center gap-0.5 min-w-[4rem]">
          <span class="text-3xl font-bold brand-name tabular-nums" id="stat-gps">0</span>
          <span class="text-xs text-base-content/45 mt-1">📍 GPS removed</span>
        </div>
        <div id="stat-dates-wrap" class="flex flex-col items-center gap-0.5 min-w-[4rem]">
          <span class="text-3xl font-bold brand-name tabular-nums" id="stat-dates">0</span>
          <span class="text-xs text-base-content/45 mt-1">📅 timestamps</span>
        </div>
        <div id="stat-kb-wrap" class="flex flex-col items-center gap-0.5 min-w-[4rem]">
          <span class="text-3xl font-bold brand-name tabular-nums" id="stat-kb">—</span>
          <span class="text-xs text-base-content/45 mt-1">💾 data stripped</span>
        </div>
      </div>
    </div>

    <div class="space-y-4 px-5 py-5 text-sm text-base-content/70 bg-base-100">
      <p>
        <strong class="font-semibold"><Brand /></strong> removes EXIF and other metadata right in your browser, so your images never leave your device and neither does any private information.
      </p>
      <p>
        I'm building this solo, for free, and without ads because privacy matters. If you find this useful, even a small donation helps keep it going.
      </p>
    </div>

    <div class="flex flex-col items-center gap-3 border-t border-base-300 px-5 py-4 text-sm text-base-content/70 text-center bg-base-100">
      <div class="flex flex-wrap items-center justify-center gap-2">
        <div id="kofi-button-container"></div>
        <script type="text/javascript" src="https://storage.ko-fi.com/cdn/widget/Widget_2.js"></script>
        <script is:inline define:vars={{ kofiId }}>kofiwidget2.init("Buy me a Ko-fi", "#ff6b6b", kofiId);kofiwidget2.draw();</script>
        <span>or</span>
        <a class="btn btn-sm text-white bg-[#0070ba] border-[#0070ba] hover:bg-[#005ea6] flex items-center gap-2 h-9 mx-1 rounded-md" href={paypalDonateUrl} target="_blank" rel="noopener noreferrer">
          <img class="w-4 h-4 shrink-0 object-contain" src="https://www.paypalobjects.com/paypal-ui/logos/svg/paypal-mark-monotone-transparent.svg" alt="PayPal logo" />
          Donate via PayPal
        </a>
      </div>
      <div class="flex items-center justify-center gap-3">
        <p>This project is open-source:</p>
        <a class="btn btn-sm btn-outline" href={githubUrl} target="_blank" rel="noopener noreferrer">🐙 Source</a>
      </div>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
