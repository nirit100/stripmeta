---
import { iconPaths } from '../lib/view/icons.ts';

interface Props {
  name: string;
  class?: string;
}

const { name, class: className = 'w-4 h-4' } = Astro.props;
---

<svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
  <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[name]} />
</svg>
