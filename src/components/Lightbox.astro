---
// Full-screen photo viewer shell. Pure markup — all behavior (navigation,
// zoom/pan gestures, object-URL lifecycle) lives in scripts/lightbox.ts, which
// binds to these ids. The viewer is opened via openLightbox() from that module.
//
// Layout: a full-bleed stage (the zoom/pan target) with frosted controls
// floating over it — a filename pill + actions on top, a toolbar pill at the
// bottom. Controls are siblings of the stage (not children), so taps on them
// never reach the gesture handlers, keeping zoom/pan confined to the photo.

const FAB =
  'flex items-center justify-center h-9 rounded-lg text-base-content/70 ' +
  'bg-base-100/70 backdrop-blur-sm border border-base-300 glass-elem shadow-sm ' +
  'hover:bg-base-200/80 hover:text-base-content transition-colors';
const PILL_BTN =
  'flex items-center justify-center w-10 h-10 rounded-full text-base-content/70 ' +
  'hover:bg-base-200/80 hover:text-base-content transition-colors disabled:opacity-30 disabled:pointer-events-none';
---

<dialog id="lightbox-modal" class="modal">
  <div class="modal-box relative max-w-none w-screen h-[100dvh] max-h-none m-0 p-0 rounded-none bg-black/85 overflow-hidden">

    <!-- Stage: full-bleed image, the zoom/pan target -->
    <div id="lb-stage" class="absolute inset-0 overflow-hidden flex items-center justify-center select-none" style="touch-action:none">
      <img id="lb-img" alt="" draggable="false" class="max-w-full max-h-full object-contain will-change-transform" />
      <div id="lb-fallback" class="hidden absolute inset-0 flex-col items-center justify-center gap-3 px-6 text-center text-white/55 pointer-events-none">
        <svg class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/></svg>
        <p class="text-sm max-w-xs leading-relaxed">This format can't be previewed in your browser, but it can still be stripped.</p>
      </div>
    </div>

    <!-- Top overlay: filename + actions (container ignores pointer events; children opt back in so gaps fall through to the stage) -->
    <div class="absolute inset-x-0 top-0 flex items-start justify-between gap-2 p-3 pointer-events-none" style="padding-top:max(0.75rem,env(safe-area-inset-top))">
      <p id="lb-name" class="pointer-events-auto min-w-0 max-w-[55%] truncate text-sm font-medium px-3 py-1.5 rounded-lg bg-base-100/70 backdrop-blur-sm border border-base-300 glass-elem shadow-sm text-base-content/80"></p>
      <div class="pointer-events-auto flex items-center gap-2 shrink-0">
        <button id="lb-reveal" type="button" title="Show this file in the list" class={`${FAB} gap-1.5 px-2.5`}>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h13M3 12h13M3 18h13M19 9l3 3-3 3"/></svg>
          <span class="hidden sm:inline text-xs font-medium">Show in list</span>
        </button>
        <button id="lb-close" type="button" title="Close (Esc)" aria-label="Close" class={`${FAB} w-9 text-base`}>✕</button>
      </div>
    </div>

    <!-- Bottom overlay: frosted toolbar pill (navigation + zoom) -->
    <div class="absolute inset-x-0 bottom-0 flex justify-center p-3 pointer-events-none" style="padding-bottom:max(0.75rem,env(safe-area-inset-bottom))">
      <div class="pointer-events-auto flex items-center gap-0.5 p-1.5 rounded-full bg-base-100/70 backdrop-blur-md border border-base-300 glass-elem shadow-lg">
        <button id="lb-prev" type="button" title="Previous (←)" aria-label="Previous" class={PILL_BTN}>
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 5l-7 7 7 7"/></svg>
        </button>
        <button id="lb-zoom-out" type="button" title="Zoom out (−)" aria-label="Zoom out" class={PILL_BTN}>
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/></svg>
        </button>
        <span id="lb-zoom-level" class="w-12 text-center text-xs tabular-nums text-base-content/60 select-none">100%</span>
        <button id="lb-zoom-in" type="button" title="Zoom in (+)" aria-label="Zoom in" class={PILL_BTN}>
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
        </button>
        <button id="lb-next" type="button" title="Next (→)" aria-label="Next" class={PILL_BTN}>
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </div>
</dialog>
