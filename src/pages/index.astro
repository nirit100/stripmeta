---
import Layout from '../layouts/Layout.astro';
import Brand from '../components/Brand.astro';
import Settings from '../components/Settings.astro';
import Lightbox from '../components/Lightbox.astro';
import Icon from '../components/Icon.astro';

const bugReportEnabled = !!import.meta.env.PUBLIC_BUG_REPORT_ENABLED;
---

<Layout title="StripMeta — Remove hidden data from your photos. No ads, no tracking.">

  <section id="hero" class="text-center flex flex-col gap-4">
    <h1 class="text-4xl font-extrabold tracking-tight">Your photos carry hidden data.</h1>
    <p class="text-base-content/60 max-w-md mx-auto leading-relaxed">
      GPS coordinates, device serial numbers, timestamps — baked into every image you share.
    </p>
    <p class="text-base-content/60 max-w-lg mx-auto leading-relaxed">
      <Brand ml={false} />
      removes them instantly, entirely in your browser!<br />
      No uploads, no servers, no tracking.
      Just control over your privacy and the information you share.
    </p>
    <div class="flex flex-wrap gap-2 justify-center mt-1">
      {['No uploads', 'No servers', 'No tracking', 'Open source'].map(label => (
        <span class="badge badge-outline badge-sm">{label}</span>
      ))}
    </div>
    <p class="text-xs text-base-content/30 max-w-sm mx-auto leading-relaxed">
      Work in progress. Strips known metadata thoroughly, but format complexity means no tool can guarantee every trace is removed.
    </p>
  </section>

  <div
    id="drop-zone"
    role="button"
    tabindex="0"
    aria-label="Drop photos here or click to select"
    class="w-full border-2 border-dashed border-base-300 rounded-2xl p-12 flex flex-col items-center gap-3 cursor-pointer transition-colors hover:border-teal-500/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-500/50"
  >
    <div id="drop-zone-content" class="flex flex-col items-center gap-3 w-full">
      <svg class="text-base-content/30" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16l4-4 4 4 4-6 4 6"/>
        <rect x="3" y="3" width="18" height="18" rx="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <p class="text-base-content/50 text-sm text-center">
        <strong class="text-base-content font-semibold">Drop photos or folders here</strong>
      </p>
      <div class="flex items-center gap-3 text-sm">
        <button id="btn-pick-files" type="button" class="btn btn-sm btn-outline">Select files</button>
        <span class="text-base-content/30 text-xs">or</span>
        <button id="btn-pick-dir" type="button" class="btn btn-sm btn-outline">📁 Open folder</button>
      </div>
      <p class="text-xs text-base-content/40">JPEG, PNG, WebP, TIFF, HEIC and more</p>
      <input id="file-input" type="file" accept="image/*,.heic,.heif,.avif" multiple class="hidden" />
      <input id="dir-input" type="file" accept="image/*,.heic,.heif,.avif" multiple webkitdirectory class="hidden" />
    </div>

    <div id="scan-state" class="hidden flex-col items-center gap-2 py-1">
      <span class="loading loading-spinner loading-md text-base-content/40"></span>
      <p class="text-sm text-base-content/50">Scanning for images…</p>
      <p id="scan-count" class="text-xs text-base-content/35 min-h-4"></p>
    </div>
  </div>

  <Settings />


  <div id="file-warning-banner" class="w-full" hidden></div>
  <div id="file-list-area" class="w-full flex flex-col gap-2">
    <div id="file-list-header" class="hidden flex items-center justify-between px-1">
      <span class="text-xs font-semibold uppercase tracking-widest text-base-content/40">Files</span>
      <span id="file-count" class="text-xs text-base-content/35 tabular-nums"></span>
    </div>
    <div id="file-list" class="flex flex-col gap-2 hidden"></div>
  </div>

  <div id="actions" class="flex gap-3 flex-wrap hidden">
    <button id="btn-strip" type="button" class="btn btn-brand">
      Strip metadata
    </button>
    <button id="btn-download" type="button" class="btn btn-brand">
      Save
    </button>
    <button id="btn-copy-result" type="button" class="btn btn-brand">
      Copy to clipboard
    </button>
    <button id="btn-clear" type="button" class="btn btn-ghost">
      Clear
    </button>
  </div>

  <p id="zip-help-hint" class="hidden w-full flex justify-center -mt-6 text-xs text-base-content/40">
    <button
      type="button"
      data-open-help="zip"
      class="inline-flex items-center gap-1 cursor-pointer underline underline-offset-2 hover:text-base-content/70 transition-colors"
    >
      <Icon name="question-mark-circle" class="w-3.5 h-3.5 shrink-0" />
      What's in this ZIP?
    </button>
  </p>

  <div id="log-wrap" class="w-full flex flex-col gap-2">
    <p id="strip-progress" class="text-xs text-base-content/35 text-center tabular-nums hidden"></p>
    <div id="log-section" class="hidden">
    <button id="btn-log-toggle" type="button"
            class="w-full px-3 py-2 text-sm rounded-lg transition-colors text-center text-base-content/30 hover:bg-base-200/50 hover:text-base-content/50">
      No issues
    </button>
    <div id="log-panel" class="hidden mt-1 rounded-xl border border-base-300 overflow-hidden">
      <ul id="log-entries" class="divide-y divide-base-300 max-h-60 overflow-y-auto"></ul>
      <div class="flex items-center justify-between px-4 py-2 border-t border-base-300">
        {(bugReportEnabled || import.meta.env.DEV) && <button type="button" class="btn btn-xs btn-ghost text-base-content/40 js-open-bug-report">Report a bug</button>}
        <button id="btn-clear-log" type="button" class="btn btn-xs btn-ghost text-base-content/40">Clear log</button>
      </div>
    </div>
  </div>
  </div>

</Layout>

<dialog id="folder-warning-modal" class="modal">
  <div class="modal-box max-w-sm p-0 overflow-hidden bg-transparent">
    <div class="flex flex-col gap-4 px-5 py-5 bg-base-100">
      <div>
        <h3 class="font-bold text-base">Large folders may freeze</h3>
        <p class="text-sm text-base-content/60 mt-1.5 leading-relaxed">
          On phones, the browser scans the entire folder before opening it. Up to ~100 photos works fine, but very large batches can freeze or crash the tab.
        </p>
        <p class="text-sm text-base-content/60 mt-2 leading-relaxed">
          For big libraries, consider selecting photos individually instead, or switch to a PC.
        </p>
      </div>
      <div class="flex gap-2 justify-end">
        <form method="dialog">
          <button class="btn btn-sm btn-ghost">Cancel</button>
        </form>
        <button id="btn-folder-warning-confirm" type="button" class="btn btn-sm btn-brand">Open folder anyway</button>
      </div>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<dialog id="metadata-modal" class="modal">
  <div class="modal-box w-full max-w-2xl max-h-[80vh] flex flex-col p-0 overflow-hidden bg-transparent">
    <div class="flex items-center gap-3 px-5 py-4 border-b border-base-300/60 shrink-0 bg-base-100/75 backdrop-blur-xl backdrop-brightness-125 glass-elem">
      <div class="flex-1 min-w-0">
        <h3 class="font-semibold text-sm truncate modal-title text-base-content/80"></h3>
        <p class="modal-handler text-xs text-base-content/45 mt-0.5 hidden leading-relaxed"></p>
      </div>
      <form method="dialog">
        <button class="btn btn-ghost btn-sm btn-circle text-base-content/50">✕</button>
      </form>
    </div>
    <div class="flex-1 overflow-y-auto px-5 py-4 modal-content bg-base-100"></div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<Lightbox />

<script>
  import '../scripts/stripper.ts';
</script>
