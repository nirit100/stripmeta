---
import Layout from '../layouts/Layout.astro';
---

<Layout title="StripMeta — Remove photo metadata privately">

  <section id="hero" class="text-center flex flex-col gap-4">
    <h1 class="text-4xl font-extrabold tracking-tight">Your photos carry hidden data.</h1>
    <p class="text-base-content/60 max-w-md mx-auto leading-relaxed">
      GPS coordinates, device serial numbers, timestamps — baked into every image you share.
    </p>
    <p class="text-base-content/60 max-w-lg mx-auto leading-relaxed">
      <strong class="inline bg-gradient-to-r from-emerald-400 via-teal-500 to-cyan-500 bg-clip-text text-transparent">StripMeta</strong>
      removes them instantly, entirely in your browser!<br />
      No uploads, no servers, no tracking.
      Just control over your privacy and the information you share.
    </p>
    <div class="flex flex-wrap gap-2 justify-center mt-1">
      {['No uploads', 'No servers', 'No tracking', 'Open source'].map(label => (
        <span class="badge badge-outline badge-sm">{label}</span>
      ))}
    </div>
  </section>

  <div
    id="drop-zone"
    role="button"
    tabindex="0"
    aria-label="Drop photos here or click to select"
    class="w-full border-2 border-dashed border-base-300 rounded-2xl p-12 flex flex-col items-center gap-3 cursor-pointer transition-colors hover:border-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"
  >
    <svg class="text-base-content/30" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16l4-4 4 4 4-6 4 6"/>
      <rect x="3" y="3" width="18" height="18" rx="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <p class="text-base-content/50 text-sm text-center">
      <strong class="text-base-content font-semibold">Drop photos here</strong> or click to select
    </p>
    <p class="text-xs text-base-content/50">JPEG, PNG, TIFF, HEIC — up to 50 files</p>
    <input id="file-input" type="file" accept="image/*" multiple class="hidden" />
  </div>

  <details id="settings-details" class="w-full group border border-base-300 rounded-xl overflow-hidden">
    <summary class="list-none flex items-center gap-2 px-4 py-3 cursor-pointer select-none hover:bg-base-200/60 transition-colors">
      <svg class="w-3 h-3 text-base-content/40 transition-transform group-open:rotate-90 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="text-xs font-medium uppercase tracking-widest text-base-content/50">Settings</span>
    </summary>
    <div class="settings-body border-t border-base-300 divide-y divide-base-300">
      <label class="flex items-center justify-between gap-4 px-4 py-3 cursor-pointer select-none hover:bg-base-200/40 transition-colors">
        <div>
          <p class="text-sm font-medium">Paranoid mode</p>
          <p class="text-xs text-base-content/50">Always re-encode via canvas — strips everything, but output is <b>always JPEG</b>. Small quality loss.</p>
          <p class="text-xs text-base-content/50">Only use when you're really paranoid.</p>
        </div>
        <input type="checkbox" id="toggle-paranoid" class="toggle toggle-sm toggle-warning shrink-0" />
      </label>
      <label class="flex items-center justify-between gap-4 px-4 py-3 cursor-pointer select-none hover:bg-base-200/40 transition-colors">
        <div>
          <p class="text-sm font-medium">Skip files with no found metadata</p>
          <p class="text-xs text-base-content/50">If disabled they will be processed anyways.</p>
        </div>
        <input type="checkbox" id="toggle-skip-clean" class="toggle toggle-sm shrink-0" checked />
      </label>
      <label class="flex items-center justify-between gap-4 px-4 py-3 cursor-pointer select-none hover:bg-base-200/40 transition-colors">
        <div>
          <p class="text-sm font-medium">Skip unsupported files</p>
          <p class="text-xs text-base-content/50">This tool really supports the most common image formats (e.g. JPEG, PNG, WEBP). If disabled, images in other formats are re-encoded to JPEG via the canvas method.</p>
        </div>
        <input type="checkbox" id="toggle-skip-unsupported" class="toggle toggle-sm shrink-0" checked />
      </label>
    </div>
  </details>


  <div id="file-warning-banner" class="w-full" hidden></div>
  <div id="file-list" class="w-full flex flex-col gap-2 hidden"></div>

  <div id="actions" class="flex gap-3 flex-wrap hidden">
    <button id="btn-strip" type="button" class="btn btn-primary">
      Strip metadata &amp; download
    </button>
    <button id="btn-clear" type="button" class="btn btn-ghost">
      Clear
    </button>
  </div>

</Layout>

<dialog id="metadata-modal" class="modal">
  <div class="modal-box w-full max-w-2xl max-h-[80vh] flex flex-col p-0 overflow-hidden">
    <div class="flex items-center gap-3 px-5 py-4 border-b border-base-300 shrink-0">
      <div class="flex-1 min-w-0">
        <h3 class="font-semibold text-sm truncate modal-title text-base-content/80"></h3>
        <p class="modal-handler text-xs text-base-content/45 mt-0.5 hidden leading-relaxed"></p>
      </div>
      <form method="dialog">
        <button class="btn btn-ghost btn-sm btn-circle text-base-content/50">✕</button>
      </form>
    </div>
    <div class="flex-1 overflow-y-auto px-5 py-4 modal-content"></div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
  import '../scripts/stripper.ts';
  import '../scripts/about.ts';
</script>
