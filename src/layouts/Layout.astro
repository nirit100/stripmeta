---
import "../styles/global.css";
import Brand from '../components/Brand.astro';
import Icon from '../components/Icon.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import AboutModal from '../components/AboutModal.astro';
import BugReportModal from '../components/BugReportModal.astro';
import { siKofi, siPaypal } from 'simple-icons';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Remove EXIF metadata from your photos privately. Everything happens in your browser — nothing is ever uploaded.",
} = Astro.props;

function optionalEnv(name: string, hint: string): string {
  const val = import.meta.env[name] as string | undefined;
  if (!val) console.warn(`[stripmeta] ${name} not set — ${hint}`);
  return val ?? '';
}

const kofiUrl       = optionalEnv('PUBLIC_KOFI_URL',      'Ko-fi button will be hidden');
const paypalUrl     = optionalEnv('PUBLIC_PAYPAL_URL',    'PayPal button will be hidden');
const privacyUrl    = optionalEnv('PUBLIC_PRIVACY_URL',   'Privacy link will be hidden');
const impressumUrl  = optionalEnv('PUBLIC_IMPRESSUM_URL', 'Impressum link will be hidden');
const bugReportEnabled = !!import.meta.env.PUBLIC_BUG_REPORT_ENABLED;
if (!bugReportEnabled) console.warn('[stripmeta] PUBLIC_BUG_REPORT_ENABLED not set — bug report button will be hidden');

const appVersion: string = __APP_VERSION__;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="apple-touch-icon" href="/icons/apple-touch.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="StripMeta" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var t = localStorage.getItem('stripmeta-theme');
        if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
        if (localStorage.getItem('stripmeta-no-glass') === '1') document.documentElement.classList.add('no-glass');
        var tc = document.querySelector('meta[name="theme-color"]');
        if (tc) {
          if (t === 'dark') { tc.setAttribute('content', '#1d232a'); }
          else if (t !== 'light') {
            if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
              tc.setAttribute('content', '#1d232a');
            }
          }
        }
      })();
    </script>
  </head>
  <body class="min-h-dvh min-w-[340px] flex flex-col bg-base-100 text-base-content">
    <header class="navbar border-b border-base-200 px-6">
      <div class="flex-1 min-w-0 flex items-center">
        <a href="/" class="hidden min-[350px]:block min-[450px]:hidden shrink-0" aria-label="StripMeta">
          <img src="/logo.svg" alt="StripMeta" class="h-7 w-auto" />
        </a>
        <a href="/" class="hidden min-[450px]:block text-xl font-bold tracking-tight shrink-0">
          <Brand />
        </a>
        <span class="ml-3 text-sm text-base-content/50 hidden min-[720px]:block truncate"
          >Remove photo metadata — privately.</span
        >
      </div>
      <div class="flex items-center gap-0.5 mr-2">
        <a href="/how-it-works" class="btn btn-ghost btn-sm text-xs text-base-content/55">How it works</a>
        <button id="btn-about-nav" type="button" class="btn btn-ghost btn-sm text-xs text-base-content/55 hidden min-[720px]:flex"><Icon name="information-circle" class="w-3.5 h-3.5" />About</button>
        <button id="btn-pwa-install" type="button" class="hidden btn btn-ghost btn-sm text-xs text-base-content/55" title="Install app">
          <Icon name="arrow-down-tray" class="w-3.5 h-3.5" /><span class="sr-only sm:not-sr-only">Install</span>
        </button>
      </div>
      <ThemeToggle />
    </header>

    <main
      class="flex-1 flex flex-col items-center px-4 pt-16 pb-8 gap-10 max-w-3xl mx-auto w-full"
    >
      <slot />
    </main>

    <footer
      class="footer footer-center py-6 text-xs text-base-content/50 border-t border-base-200"
    >
      <div
        class="w-full max-w-3xl mx-auto flex flex-col min-[720px]:flex-row items-center min-[720px]:justify-between gap-3 px-4"
      >
        <div class="flex flex-col gap-1 text-center min-[720px]:text-left">
          <p class="m-0">
            Everything runs locally. Nothing leaves your device.
             <span class="mx-1">·</span>
            <a href="/how-it-works" class="text-base-content/40 hover:text-base-content/70 transition-colors underline underline-offset-2 whitespace-nowrap">How it works</a>
          </p>
          <p class="m-0 text-[0.65rem] text-base-content/30 font-mono">
            {(privacyUrl || impressumUrl) && <>
              {privacyUrl && <a href={privacyUrl} class="hover:text-base-content/60 transition-colors underline underline-offset-2 whitespace-nowrap">Privacy</a>}
              {privacyUrl && impressumUrl && <span class="mx-1">·</span>}
              {impressumUrl && <a href={impressumUrl} class="hover:text-base-content/60 transition-colors underline underline-offset-2 whitespace-nowrap">Impressum</a>}
              <span class="mx-1">·</span>
            </>}
            <span title="Version">{appVersion}</span>
          </p>
        </div>
        <div class="flex items-center gap-2">
          {(bugReportEnabled || import.meta.env.DEV) && <button class="btn btn-xs btn-ghost js-open-bug-report">🐛 Report a bug</button>}
          <div class="relative inline-flex">
            <span id="about-badge" class="hidden absolute -top-1 -right-1 z-10 pointer-events-none">
              <span class="relative flex h-2.5 w-2.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-400"></span>
              </span>
            </span>
            <button id="btn-about-footer" class="btn btn-xs btn-ghost"><Icon name="information-circle" class="w-3.5 h-3.5" />About</button>
          </div>
          {kofiUrl && <a
            class="btn btn-xs btn-outline overflow-hidden footer-donate-btn hover:bg-[#FF5E78] hover:text-white hover:border-[#FF5E78]"
            href={kofiUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Buy me a coffee on Ko-fi">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={siKofi.path}/></svg>
            Ko-fi</a>}
          {paypalUrl && <a
            class="btn btn-xs btn-outline overflow-hidden footer-donate-btn hover:bg-[#0070ba] hover:text-white hover:border-[#0070ba]"
            href={paypalUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Donate via PayPal">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={siPaypal.path}/></svg>
            PayPal</a>}
        </div>
      </div>
    </footer>

    <AboutModal />
    <BugReportModal />

    <dialog id="pwa-install-modal" class="modal">
      <div class="modal-box max-w-sm p-0 overflow-hidden flex flex-col">

        <div class="flex items-center gap-3 px-5 py-4 border-b border-base-300/60 shrink-0 bg-base-100/75 backdrop-blur-xl backdrop-brightness-125 glass-elem">
          <div class="flex-1 min-w-0">
            <h3 id="pwa-modal-title" class="font-bold text-lg">Oh, it's you again 👀</h3>
          </div>
          <form method="dialog">
            <button class="btn btn-ghost btn-sm btn-circle text-base-content/50">✕</button>
          </form>
        </div>

        <div class="px-5 py-5 flex flex-col gap-3 text-sm text-base-content/75 bg-base-100">
          <p id="pwa-modal-intro">I noticed you've dropped by a couple of times now. I wasn't going to say anything, but since we're basically old friends at this point —</p>
          <p>Want to make this a little more permanent? <strong class="text-base-content">Installing <Brand /> adds it to your home screen like a real app</strong>: instant launch, full offline support, no app store.</p>
          <p class="text-xs text-base-content/45">Your photos still stay on your device. <br />That part doesn't change.</p>
        </div>

        <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-base-300/60 bg-base-100">
          <button id="pwa-prompt-dismiss" type="button" class="btn btn-ghost btn-sm text-base-content/55">No, thanks</button>
          <button id="pwa-prompt-install" type="button" class="btn btn-sm btn-brand">Install it!</button>
        </div>

      </div>
      <form method="dialog" class="modal-backdrop"><button>close</button></form>
    </dialog>

    <script>
      import '../scripts/footer.ts';
      import '../scripts/bugReport.ts';
      import '../scripts/about.ts';
      import '../scripts/pwa.ts';
    </script>
    {!import.meta.env.DEV && (
      <script is:inline>
        if ('serviceWorker' in navigator) {
          window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js'));
        }
      </script>
    )}
  </body>
</html>
