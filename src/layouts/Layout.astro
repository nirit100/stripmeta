---
import "../styles/global.css";
import Brand from '../components/Brand.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import AboutModal from '../components/AboutModal.astro';
import BugReportModal from '../components/BugReportModal.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Remove EXIF metadata from your photos privately. Everything happens in your browser — nothing is ever uploaded.",
} = Astro.props;

function optionalEnv(name: string, hint: string): string {
  const val = import.meta.env[name] as string | undefined;
  if (!val) console.warn(`[stripmeta] ${name} not set — ${hint}`);
  return val ?? '';
}

const kofiUrl       = optionalEnv('PUBLIC_KOFI_URL',      'Ko-fi button will be hidden');
const paypalUrl     = optionalEnv('PUBLIC_PAYPAL_URL',    'PayPal button will be hidden');
const privacyUrl    = optionalEnv('PUBLIC_PRIVACY_URL',   'Privacy link will be hidden');
const impressumUrl  = optionalEnv('PUBLIC_IMPRESSUM_URL', 'Impressum link will be hidden');
const bugReportEnabled = !!import.meta.env.PUBLIC_BUG_REPORT_ENABLED;
if (!bugReportEnabled) console.warn('[stripmeta] PUBLIC_BUG_REPORT_ENABLED not set — bug report button will be hidden');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!--link rel="icon" type="image/x-icon" href="/favicon.ico" /-->
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        const t = localStorage.getItem('stripmeta-theme');
        if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
        if (localStorage.getItem('stripmeta-no-glass') === '1') document.documentElement.classList.add('no-glass');
      })();
    </script>
  </head>
  <body class="min-h-dvh flex flex-col bg-base-100 text-base-content">
    <header class="navbar border-b border-base-200 px-6">
      <div class="flex-1 min-w-0 flex items-center">
        <a href="/" class="text-xl font-bold tracking-tight shrink-0">
          <Brand />
        </a>
        <span class="ml-3 text-sm text-base-content/50 hidden sm:block truncate"
          >Remove photo metadata — privately.</span
        >
      </div>
      <div class="flex items-center gap-0.5 mr-2">
        <a href="/how-it-works" class="btn btn-ghost btn-sm text-xs text-base-content/55">How it works</a>
        <button id="btn-about-nav" type="button" class="btn btn-ghost btn-sm text-xs text-base-content/55 hidden sm:flex">About</button>
      </div>
      <ThemeToggle />
    </header>

    <main
      class="flex-1 flex flex-col items-center px-4 pt-16 pb-8 gap-10 max-w-3xl mx-auto w-full"
    >
      <slot />
    </main>

    <footer
      class="footer footer-center py-6 text-xs text-base-content/50 border-t border-base-200"
    >
      <div
        class="w-full max-w-3xl mx-auto flex flex-col sm:flex-row items-center sm:justify-between gap-3 px-4"
      >
        <div class="flex flex-col gap-1 text-center sm:text-left">
          <p class="m-0">
            Everything runs locally. Nothing leaves your device.
             <span class="mx-1">·</span>
            <a href="/how-it-works" class="text-base-content/40 hover:text-base-content/70 transition-colors underline underline-offset-2 whitespace-nowrap">How it works</a>
          </p>
          {(privacyUrl || impressumUrl) && (
            <p class="m-0 text-[0.65rem] text-base-content/30">
              {privacyUrl && <a href={privacyUrl} class="hover:text-base-content/60 transition-colors underline underline-offset-2 whitespace-nowrap">Privacy</a>}
              {privacyUrl && impressumUrl && <span class="mx-1">·</span>}
              {impressumUrl && <a href={impressumUrl} class="hover:text-base-content/60 transition-colors underline underline-offset-2 whitespace-nowrap">Impressum</a>}
            </p>
          )}
        </div>
        <div class="flex items-center gap-2">
          {kofiUrl && <a
            class="btn btn-xs btn-outline overflow-hidden footer-donate-btn hover:bg-[#FF5E78] hover:text-white hover:border-[#FF5E78]"
            href={kofiUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Buy me a coffee on Ko-fi">☕ Ko-fi</a>}
          {paypalUrl && <a
            class="btn btn-xs btn-outline overflow-hidden footer-donate-btn hover:bg-[#0070ba] hover:text-white hover:border-[#0070ba]"
            href={paypalUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Donate via PayPal">💸 PayPal</a>}
          {bugReportEnabled && <button class="btn btn-xs btn-ghost js-open-bug-report">🐛 Report a bug</button>}
          <div class="relative inline-flex">
            <span id="about-badge" class="hidden absolute -top-1 -right-1 z-10 pointer-events-none">
              <span class="relative flex h-2.5 w-2.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-400"></span>
              </span>
            </span>
            <button id="btn-about-footer" class="btn btn-xs btn-ghost">ℹ️ About</button>
          </div>
        </div>
      </div>
    </footer>

    <AboutModal />
    <BugReportModal />
    <script>
      import '../scripts/footer.ts';
      import '../scripts/bugReport.ts';
    </script>
  </body>
</html>
