---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Remove EXIF metadata from your photos privately. Everything happens in your browser — nothing is ever uploaded.',
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} // UNDER CONSTRUCTION</title>
  </head>
  <body class="min-h-dvh flex flex-col bg-base-100 text-base-content">

    <header class="navbar border-b border-base-200 px-6">
      <div class="flex-1">
        <a href="/" class="text-xl font-bold tracking-tight bg-gradient-to-r from-emerald-400 via-teal-500 to-cyan-500 bg-clip-text text-transparent">StripMeta</a>
        <span class="ml-3 text-sm text-base-content/50 hidden sm:inline">Remove photo metadata — privately.</span>
      </div>
    </header>

    <main class="flex-1 flex flex-col items-center px-4 py-16 gap-10 max-w-3xl mx-auto w-full">
      <slot />
    </main>

    <footer class="footer footer-center py-6 text-xs text-base-content/30 border-t border-base-200">
      <p>Everything runs in your browser. No images and no info about them ever leave your device.</p>
    </footer>

  </body>
</html>
